{
    "name": "apexsociety",
    "version": "1.0.0",
    "description": "ApexSociety - The social platform for car enthusiasts. Find meets, join crews, and share your automotive lifestyle.",
    "main": "index.ts",
    "author": "ApexSociety",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/juninmd/ApexSociety.git"
    },
    "homepage": "https://juninmd.github.io/ApexSociety",
    "keywords": [
        "react-native",
        "expo",
        "social",
        "cars"
    ],
    "scripts": {
        "start": "expo start",
        "android": "expo start --android",
        "ios": "expo start --ios",
        "preweb": "node scripts/update-html-metadata.js && node scripts/generate-sitemap.js && node scripts/generate-security-txt.js",
        "web": "expo start --web",
        "build:web": "expo export -p web",
        "prebuild:web": "node scripts/update-html-metadata.js && node scripts/generate-sitemap.js && node scripts/generate-security-txt.js",
        "build:gh-pages": "cross-env GH_PAGES=true expo export -p web && node scripts/cp-404.js",
        "prebuild:gh-pages": "node scripts/update-html-metadata.js && node scripts/generate-sitemap.js && node scripts/generate-security-txt.js",
        "deploy": "pnpm run build:gh-pages && gh-pages -d dist",
        "deploy:netlify": "netlify deploy --prod --dir=dist",
        "test:ci": "jest --ci --coverage",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "jest",
        "prepare": "husky",
        "preview": "serve dist"
    },
    "dependencies": {
        "@expo-google-fonts/oswald": "^0.4.2",
        "@expo-google-fonts/roboto": "^0.4.3",
        "@expo/metro-runtime": "~6.1.2",
        "@react-navigation/bottom-tabs": "^7.14.0",
        "@react-navigation/native": "^7.1.28",
        "@react-navigation/native-stack": "^7.13.0",
        "expo": "~54.0.33",
        "expo-blur": "^15.0.8",
        "expo-font": "^14.0.11",
        "expo-linear-gradient": "^15.0.8",
        "expo-linking": "^8.0.11",
        "expo-location": "^19.0.8",
        "expo-status-bar": "~3.0.9",
        "follow-redirects": "^1.16.0",
        "lucide-react-native": "^0.563.0",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-native": "0.81.5",
        "react-native-maps": "1.20.1",
        "react-native-safe-area-context": "5.6.2",
        "react-native-screens": "4.16.0",
        "react-native-svg": "15.12.1",
        "react-native-web": "^0.21.2"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@testing-library/react-native": "^13.3.3",
        "@types/jest": "29.5.14",
        "@types/node": "^25.3.0",
        "@types/react": "~19.1.17",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "cross-env": "^10.1.0",
        "eslint": "^9.0.0",
        "eslint-config-expo": "^10.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-prettier": "^5.5.5",
        "gh-pages": "^6.3.0",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "jest-expo": "^54.0.17",
        "lint-staged": "^16.2.7",
        "netlify-cli": "^24.4.1",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "react-test-renderer": "^19.1.0",
        "tar": "^7.5.10",
        "typescript": "~5.4.5"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    },
    "pnpm": {
        "overrides": {
            "minimatch": "^9.0.7",
            "@tootallnate/once": "^3.0.1",
            "test-exclude": "^7.0.1",
            "undici": "^6.24.1",
            "flatted": "^3.4.2",
            "fastify": ">=5.8.5",
            "@fastify/static": ">=9.1.1",
            "brace-expansion": "^2.0.1",
            "picomatch": ">=4.0.4",
            "follow-redirects": "^1.16.0",
            "yaml": ">=2.8.3",
            "path-to-regexp": ">=8.4.0",
            "lodash": ">=4.18.0",
            "cookie": ">=1.0.2",
            "@xmldom/xmldom": ">=0.9.10",
            "postcss": ">=8.5.10",
            "uuid": ">=14.0.0",
            "node-forge": ">=1.4.0",
            "defu": ">=6.1.5"
        }
    },
    "private": true
}
