{
    "name": "apexsociety",
    "version": "1.0.0",
    "description": "ApexSociety - The social platform for car enthusiasts. Find meets, join crews, and share your automotive lifestyle.",
    "main": "index.ts",
    "author": "ApexSociety",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/apexsociety/apexsociety.git"
    },
    "homepage": "https://apexsociety.github.io/apexsociety",
    "keywords": [
        "react-native",
        "expo",
        "social",
        "cars"
    ],
    "scripts": {
        "start": "expo start",
        "android": "expo start --android",
        "ios": "expo start --ios",
        "web": "expo start --web",
        "build:web": "expo export -p web",
        "build:gh-pages": "cross-env GH_PAGES=true expo export -p web",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "jest",
        "prepare": "husky"
    },
    "dependencies": {
        "@expo-google-fonts/oswald": "^0.4.2",
        "@expo-google-fonts/roboto": "^0.4.2",
        "@expo/metro-runtime": "~6.1.2",
        "@react-navigation/bottom-tabs": "^7.12.0",
        "@react-navigation/native": "^7.1.28",
        "@react-navigation/native-stack": "^7.12.0",
        "expo": "~54.0.33",
        "expo-blur": "^15.0.8",
        "expo-font": "^14.0.11",
        "expo-linear-gradient": "^15.0.8",
        "expo-location": "^19.0.8",
        "expo-status-bar": "~3.0.9",
        "lucide-react-native": "^0.563.0",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-native": "0.81.5",
        "react-native-maps": "^1.27.1",
        "react-native-safe-area-context": "^5.6.2",
        "react-native-screens": "^4.23.0",
        "react-native-svg": "^15.15.2",
        "react-native-web": "^0.21.2"
    },
    "devDependencies": {
        "@testing-library/react-native": "^13.3.3",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.3.0",
        "@types/react": "~19.1.0",
        "cross-env": "^10.1.0",
        "eslint": "^9.39.2",
        "eslint-config-expo": "^10.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "jest-expo": "^54.0.17",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1",
        "react-test-renderer": "^19.1.0",
        "typescript": "~5.9.2"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    },
    "private": true
}
